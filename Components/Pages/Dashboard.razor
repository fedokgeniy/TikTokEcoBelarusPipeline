@page "/"
@rendermode InteractiveServer
@using TikTokEcoBelarus.Infrastructure
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory

<h4 class="mb-4">📊 Общая статистика</h4>

@if (_loading)
{
    <p>Загрузка...</p>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">🎥 Видео</h5>
                    <p class="display-6">@_videoCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">💬 Комментарии</h5>
                    <p class="display-6">@_commentCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">🔍 Запросы</h5>
                    <p class="display-6">@_queryCount</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center">
                <div class="card-body">
                    <h5 class="card-title">📁 Каналы</h5>
                    <p class="display-6">@_channelCount</p>
                </div>
            </div>
        </div>
    </div>
}

@code {
    bool _loading = true;
    int _videoCount, _commentCount, _queryCount, _channelCount;

    protected override async Task OnInitializedAsync()
    {
        await using var db = DbFactory.CreateDbContext();
        _videoCount   = await db.Videos.CountAsync();
        _commentCount = await db.VideoComments.CountAsync();
        _queryCount   = await db.SearchQueries.CountAsync(q => q.IsActive);
        _channelCount = await db.TrackedChannels.CountAsync(c => c.IsActive);
        _loading = false;
    }
}
