@page "/scoring"
@rendermode InteractiveServer
@using TikTokEcoBelarus.Domain.Entities
@using TikTokEcoBelarus.Infrastructure
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using System.Text.Json.Serialization
@using System.Text.Encodings.Web
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS

<h4 class="mb-3">🎯 Scoring Profile</h4>

<div class="d-flex gap-2 mb-4 flex-wrap">
    <button class="btn btn-outline-primary" @onclick="ExportJson">⬇️ Скачать JSON</button>
    <label class="btn btn-outline-success mb-0">
        ⬆️ Загрузить JSON
        <InputFile OnChange="ImportJson" accept=".json" style="display:none" />
    </label>
    @if (_importMsg != null)
    {
        <span class="@(_importError ? "text-danger" : "text-success") small align-self-center">@_importMsg</span>
    }
</div>

<!-- Фильтры -->
<div class="row g-2 mb-3">
    <div class="col-md-3">
        <input class="form-control form-control-sm" placeholder="Поиск по Keyword"
               @bind="_filterKeyword" @bind:event="oninput" />
    </div>
    <div class="col-md-3">
        <input class="form-control form-control-sm" placeholder="Поиск по Category"
               @bind="_filterCategory" @bind:event="oninput" />
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="_filterScoreType">
            <option value="">(все ScoreType)</option>
            <option value="eco">eco</option>
            <option value="belarus">belarus</option>
        </select>
    </div>
    <div class="col-md-1">
        <button class="btn btn-sm btn-outline-secondary w-100" @onclick="ResetFilters">Сброс</button>
    </div>
</div>

@if (_loading)
{
    <div class="d-flex align-items-center gap-2 text-muted">
        <div class="spinner-border spinner-border-sm"></div>
        <span>Загрузка...</span>
    </div>
}
else
{
    <!-- ===== RULES ===== -->
    <div class="d-flex justify-content-between align-items-center mt-2 mb-1">
        <h5 class="mb-0">Правила (показано: @FilteredRules.Count / @_rules.Count)</h5>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => _addRuleOpen = !_addRuleOpen">➕ Добавить правило</button>
    </div>

    @if (_addRuleOpen)
    {
        <div class="card card-body mb-3 border-primary">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label form-label-sm mb-0">Keyword</label>
                    <input class="form-control form-control-sm" @bind="_newRule.Keyword" placeholder="например: экология" />
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm mb-0">Category</label>
                    <input class="form-control form-control-sm" @bind="_newRule.Category" placeholder="Eco_Topic" />
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm mb-0">ScoreType</label>
                    <select class="form-select form-select-sm" @bind="_newRule.ScoreType">
                        <option>eco</option>
                        <option>belarus</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="form-label form-label-sm mb-0">Weight</label>
                    <input class="form-control form-control-sm" type="number" step="0.01" @bind="_newRule.Weight" />
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm mb-0">SearchContext</label>
                    <select class="form-select form-select-sm" @bind="_newRule.SearchContext">
                        <option>any</option>
                        <option>hashtags</option>
                        <option>bio</option>
                        <option>description</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="form-label form-label-sm mb-0">MaxMatches</label>
                    <input class="form-control form-control-sm" type="number" @bind="_newRule.MaxMatches" />
                </div>
                <div class="col-md-1 d-flex align-items-end gap-2">
                    <div class="form-check mt-1">
                        <input type="checkbox" class="form-check-input" id="newRuleActive" @bind="_newRule.IsActive" />
                        <label class="form-check-label small" for="newRuleActive">Active</label>
                    </div>
                </div>
            </div>
            @if (_addRuleError != null)
            {
                <div class="text-danger small mt-1">@_addRuleError</div>
            }
            <div class="mt-2 d-flex gap-2">
                <button class="btn btn-sm btn-primary" @onclick="AddRule">✓ Сохранить</button>
                <button class="btn btn-sm btn-secondary" @onclick="() => { _addRuleOpen = false; _addRuleError = null; }">Отмена</button>
            </div>
        </div>
    }

    <table class="table table-sm table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Keyword</th><th>Category</th><th>ScoreType</th>
                <th>Weight</th><th>SearchContext</th><th>MaxMatches</th><th>Active</th><th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in FilteredRules)
            {
                if (_editRuleId == r.Id)
                {
                    <tr class="table-warning">
                        <td><input class="form-control form-control-sm" @bind="_editRule!.Keyword" /></td>
                        <td><input class="form-control form-control-sm" @bind="_editRule!.Category" /></td>
                        <td>
                            <select class="form-select form-select-sm" @bind="_editRule!.ScoreType">
                                <option>eco</option>
                                <option>belarus</option>
                            </select>
                        </td>
                        <td><input class="form-control form-control-sm" type="number" step="0.01" @bind="_editRule!.Weight" /></td>
                        <td>
                            <select class="form-select form-select-sm" @bind="_editRule!.SearchContext">
                                <option>any</option>
                                <option>hashtags</option>
                                <option>bio</option>
                                <option>description</option>
                            </select>
                        </td>
                        <td><input class="form-control form-control-sm" type="number" @bind="_editRule!.MaxMatches" /></td>
                        <td><input type="checkbox" class="form-check-input" @bind="_editRule!.IsActive" /></td>
                        <td class="d-flex gap-1">
                            <button class="btn btn-sm btn-success" @onclick="SaveRule">✓</button>
                            <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">✕</button>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td>@r.Keyword</td>
                        <td><span class="badge bg-secondary">@r.Category</span></td>
                        <td><span class="badge @(r.ScoreType=="belarus" ? "bg-warning text-dark" : "bg-success")">@r.ScoreType</span></td>
                        <td>@r.Weight</td>
                        <td><code>@r.SearchContext</code></td>
                        <td>@r.MaxMatches</td>
                        <td>@(r.IsActive ? "✓" : "✗")</td>
                        <td><button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditRule(r)">✏️</button></td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <!-- ===== THRESHOLDS ===== -->
    <div class="d-flex justify-content-between align-items-center mt-4 mb-1">
        <h5 class="mb-0">Пороги (показано: @FilteredThresholds.Count / @_thresholds.Count)</h5>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => _addThresholdOpen = !_addThresholdOpen">➕ Добавить порог</button>
    </div>

    @if (_addThresholdOpen)
    {
        <div class="card card-body mb-3 border-primary">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label form-label-sm mb-0">Category</label>
                    <input class="form-control form-control-sm" @bind="_newThreshold.Category" placeholder="Eco_Topic" />
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm mb-0">ScoreType</label>
                    <select class="form-select form-select-sm" @bind="_newThreshold.ScoreType">
                        <option>eco</option>
                        <option>belarus</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm mb-0">MinMatchCount</label>
                    <input class="form-control form-control-sm" type="number" @bind="_newThreshold.MinMatchCount" />
                </div>
                <div class="col-md-2">
                    <label class="form-label form-label-sm mb-0">ScoreBonus</label>
                    <input class="form-control form-control-sm" type="number" step="0.01" @bind="_newThreshold.ScoreBonus" />
                </div>
            </div>
            @if (_addThresholdError != null)
            {
                <div class="text-danger small mt-1">@_addThresholdError</div>
            }
            <div class="mt-2 d-flex gap-2">
                <button class="btn btn-sm btn-primary" @onclick="AddThreshold">✓ Сохранить</button>
                <button class="btn btn-sm btn-secondary" @onclick="() => { _addThresholdOpen = false; _addThresholdError = null; }">Отмена</button>
            </div>
        </div>
    }

    <table class="table table-sm table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Category</th><th>ScoreType</th><th>MinMatchCount</th><th>ScoreBonus</th><th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in FilteredThresholds)
            {
                if (_editThresholdId == t.Id)
                {
                    <tr class="table-warning">
                        <td><input class="form-control form-control-sm" @bind="_editThreshold!.Category" /></td>
                        <td>
                            <select class="form-select form-select-sm" @bind="_editThreshold!.ScoreType">
                                <option>eco</option>
                                <option>belarus</option>
                            </select>
                        </td>
                        <td><input class="form-control form-control-sm" type="number" @bind="_editThreshold!.MinMatchCount" /></td>
                        <td><input class="form-control form-control-sm" type="number" step="0.01" @bind="_editThreshold!.ScoreBonus" /></td>
                        <td class="d-flex gap-1">
                            <button class="btn btn-sm btn-success" @onclick="SaveThreshold">✓</button>
                            <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">✕</button>
                        </td>
                    </tr>
                }
                else
                {
                    <tr>
                        <td><span class="badge bg-secondary">@t.Category</span></td>
                        <td><span class="badge @(t.ScoreType=="belarus" ? "bg-warning text-dark" : "bg-success")">@t.ScoreType</span></td>
                        <td>@t.MinMatchCount</td>
                        <td>@t.ScoreBonus</td>
                        <td><button class="btn btn-sm btn-outline-secondary" @onclick="() => StartEditThreshold(t)">✏️</button></td>
                    </tr>
                }
            }
        </tbody>
    </table>
}

@code {
    bool    _loading     = true;
    string? _importMsg   = null;
    bool    _importError = false;

    List<ScoringRule>          _rules      = [];
    List<ScoringRuleThreshold> _thresholds = [];

    string _filterKeyword   = "";
    string _filterCategory  = "";
    string _filterScoreType = "";

    // inline edit
    Guid?        _editRuleId;      ScoringRule?          _editRule;
    Guid?        _editThresholdId; ScoringRuleThreshold? _editThreshold;

    // add rule form
    bool    _addRuleOpen  = false;
    string? _addRuleError;
    ScoringRule _newRule  = new() { ScoreType = "eco", SearchContext = "any", MaxMatches = 1, IsActive = true };

    // add threshold form
    bool    _addThresholdOpen  = false;
    string? _addThresholdError;
    ScoringRuleThreshold _newThreshold = new() { ScoreType = "eco" };

    List<ScoringRule> FilteredRules => _rules
        .Where(r => string.IsNullOrEmpty(_filterKeyword)   || r.Keyword.Contains(_filterKeyword,   StringComparison.OrdinalIgnoreCase))
        .Where(r => string.IsNullOrEmpty(_filterCategory)  || r.Category.Contains(_filterCategory,  StringComparison.OrdinalIgnoreCase))
        .Where(r => string.IsNullOrEmpty(_filterScoreType) || r.ScoreType == _filterScoreType)
        .OrderBy(r => r.ScoreType).ThenBy(r => r.Category)
        .ToList();

    List<ScoringRuleThreshold> FilteredThresholds => _thresholds
        .Where(t => string.IsNullOrEmpty(_filterCategory)  || t.Category.Contains(_filterCategory,  StringComparison.OrdinalIgnoreCase))
        .Where(t => string.IsNullOrEmpty(_filterScoreType) || t.ScoreType == _filterScoreType)
        .OrderBy(t => t.ScoreType).ThenBy(t => t.Category)
        .ToList();

    static readonly JsonSerializerOptions _exportOptions = new()
    {
        WriteIndented = true,
        Encoder       = JavaScriptEncoder.UnsafeRelaxedJsonEscaping
    };

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        _loading = true;
        StateHasChanged();
        await using var db = await DbFactory.CreateDbContextAsync();
        _rules      = await db.ScoringRules.AsNoTracking().ToListAsync();
        _thresholds = await db.ScoringRuleThresholds.AsNoTracking().ToListAsync();
        _loading = false;
    }

    void ResetFilters() { _filterKeyword = ""; _filterCategory = ""; _filterScoreType = ""; }

    // ---- Add Rule ----
    async Task AddRule()
    {
        _addRuleError = null;
        if (string.IsNullOrWhiteSpace(_newRule.Keyword))  { _addRuleError = "Keyword обязателен"; return; }
        if (string.IsNullOrWhiteSpace(_newRule.Category)) { _addRuleError = "Category обязателен"; return; }

        await using var db = await DbFactory.CreateDbContextAsync();
        db.ScoringRules.Add(new ScoringRule
        {
            Keyword       = _newRule.Keyword.Trim(),
            Category      = _newRule.Category.Trim(),
            ScoreType     = _newRule.ScoreType,
            Weight        = _newRule.Weight,
            SearchContext = _newRule.SearchContext,
            MaxMatches    = _newRule.MaxMatches,
            IsActive      = _newRule.IsActive
        });
        await db.SaveChangesAsync();
        _newRule       = new() { ScoreType = "eco", SearchContext = "any", MaxMatches = 1, IsActive = true };
        _addRuleOpen   = false;
        await LoadAsync();
    }

    // ---- Add Threshold ----
    async Task AddThreshold()
    {
        _addThresholdError = null;
        if (string.IsNullOrWhiteSpace(_newThreshold.Category)) { _addThresholdError = "Category обязателен"; return; }

        await using var db = await DbFactory.CreateDbContextAsync();
        db.ScoringRuleThresholds.Add(new ScoringRuleThreshold
        {
            Category      = _newThreshold.Category.Trim(),
            ScoreType     = _newThreshold.ScoreType,
            MinMatchCount = _newThreshold.MinMatchCount,
            ScoreBonus    = _newThreshold.ScoreBonus
        });
        await db.SaveChangesAsync();
        _newThreshold      = new() { ScoreType = "eco" };
        _addThresholdOpen  = false;
        await LoadAsync();
    }

    // ---- Edit Rule ----
    void StartEditRule(ScoringRule r)
    {
        _editThresholdId = null; _editThreshold = null;
        _editRuleId = r.Id;
        _editRule   = new ScoringRule
        {
            Id = r.Id, Keyword = r.Keyword, Category = r.Category,
            ScoreType = r.ScoreType, Weight = r.Weight,
            SearchContext = r.SearchContext, MaxMatches = r.MaxMatches,
            IsActive = r.IsActive, CreatedAt = r.CreatedAt
        };
    }

    async Task SaveRule()
    {
        if (_editRule == null) return;
        var saved = _editRule;
        await using var db = await DbFactory.CreateDbContextAsync();
        await db.ScoringRules
            .Where(r => r.Id == saved.Id)
            .ExecuteUpdateAsync(s => s
                .SetProperty(r => r.Keyword,       saved.Keyword)
                .SetProperty(r => r.Category,      saved.Category)
                .SetProperty(r => r.ScoreType,     saved.ScoreType)
                .SetProperty(r => r.Weight,        saved.Weight)
                .SetProperty(r => r.SearchContext, saved.SearchContext)
                .SetProperty(r => r.MaxMatches,    saved.MaxMatches)
                .SetProperty(r => r.IsActive,      saved.IsActive));
        CancelEdit();
        await LoadAsync();
    }

    // ---- Edit Threshold ----
    void StartEditThreshold(ScoringRuleThreshold t)
    {
        _editRuleId = null; _editRule = null;
        _editThresholdId = t.Id;
        _editThreshold   = new ScoringRuleThreshold
        {
            Id = t.Id, Category = t.Category, ScoreType = t.ScoreType,
            MinMatchCount = t.MinMatchCount, ScoreBonus = t.ScoreBonus
        };
    }

    async Task SaveThreshold()
    {
        if (_editThreshold == null) return;
        var saved = _editThreshold;
        await using var db = await DbFactory.CreateDbContextAsync();
        await db.ScoringRuleThresholds
            .Where(t => t.Id == saved.Id)
            .ExecuteUpdateAsync(s => s
                .SetProperty(t => t.Category,      saved.Category)
                .SetProperty(t => t.ScoreType,     saved.ScoreType)
                .SetProperty(t => t.MinMatchCount, saved.MinMatchCount)
                .SetProperty(t => t.ScoreBonus,    saved.ScoreBonus));
        CancelEdit();
        await LoadAsync();
    }

    void CancelEdit()
    {
        _editRuleId      = null; _editRule      = null;
        _editThresholdId = null; _editThreshold = null;
    }

    // ---- Export / Import ----
    async Task ExportJson()
    {
        var profile = new ScoringProfileDto
        {
            Rules = _rules.Select(r => new RuleDto
            {
                Keyword = r.Keyword, Category = r.Category, ScoreType = r.ScoreType,
                Weight  = r.Weight,  SearchContext = r.SearchContext,
                MaxMatches = r.MaxMatches, IsActive = r.IsActive
            }).ToList(),
            Thresholds = _thresholds.Select(t => new ThresholdDto
            {
                Category = t.Category, ScoreType = t.ScoreType,
                MinMatchCount = t.MinMatchCount, ScoreBonus = t.ScoreBonus
            }).ToList()
        };
        var json  = JsonSerializer.Serialize(profile, _exportOptions);
        var bytes = System.Text.Encoding.UTF8.GetBytes(json);
        var b64   = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFileFromBase64", "scoring-profile.json", "application/json", b64);
    }

    async Task ImportJson(InputFileChangeEventArgs e)
    {
        _importMsg = null; _importError = false;
        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 1024 * 1024);
            var profile = await JsonSerializer.DeserializeAsync<ScoringProfileDto>(stream,
                new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (profile == null) throw new Exception("Пустой файл");
            await using var db = await DbFactory.CreateDbContextAsync();
            await db.ScoringRules.ExecuteDeleteAsync();
            await db.ScoringRuleThresholds.ExecuteDeleteAsync();
            db.ScoringRules.AddRange(profile.Rules.Select(r => new ScoringRule
            {
                Keyword = r.Keyword, Category = r.Category, ScoreType = r.ScoreType,
                Weight  = r.Weight,  SearchContext = r.SearchContext,
                MaxMatches = r.MaxMatches, IsActive = r.IsActive
            }));
            db.ScoringRuleThresholds.AddRange(profile.Thresholds.Select(t => new ScoringRuleThreshold
            {
                Category = t.Category, ScoreType = t.ScoreType,
                MinMatchCount = t.MinMatchCount, ScoreBonus = t.ScoreBonus
            }));
            await db.SaveChangesAsync();
            _importMsg = $"✓ Загружено: {profile.Rules.Count} правил, {profile.Thresholds.Count} порогов";
            await LoadAsync();
        }
        catch (Exception ex) { _importError = true; _importMsg = $"Ошибка: {ex.Message}"; }
    }

    record ScoringProfileDto
    {
        public List<RuleDto>      Rules      { get; init; } = [];
        public List<ThresholdDto> Thresholds { get; init; } = [];
    }
    record RuleDto
    {
        public string  Keyword       { get; init; } = "";
        public string  Category      { get; init; } = "";
        public string  ScoreType     { get; init; } = "";
        public decimal Weight        { get; init; }
        public string  SearchContext { get; init; } = "any";
        public int     MaxMatches    { get; init; } = 1;
        public bool    IsActive      { get; init; } = true;
    }
    record ThresholdDto
    {
        public string  Category      { get; init; } = "";
        public string  ScoreType     { get; init; } = "";
        public int     MinMatchCount { get; init; }
        public decimal ScoreBonus    { get; init; }
    }
}
