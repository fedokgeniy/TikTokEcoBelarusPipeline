@page "/channels"
@rendermode InteractiveServer
@using TikTokEcoBelarus.Infrastructure
@using TikTokEcoBelarus.Domain.Entities
@using TikTokEcoBelarus.Pipeline
@using TikTokEcoBelarus.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject ITrackedChannelRepository ChannelRepo
@inject ChannelMonitorPipeline MonitorPipeline
@inject TikTokApiClient TikTokApi

<h4 class="mb-3">📡 Отслеживаемые каналы</h4>

@if (_loading)
{
    <p>Загрузка...</p>
}
else
{
    <table class="table table-sm table-hover">
        <thead><tr><th>@@ UniqueId</th><th>Название</th><th>Активен</th><th>Видео</th><th>Комменты</th><th>Проверка</th><th></th></tr></thead>
        <tbody>
        @foreach (var ch in _channels)
        {
            <tr>
                <td><a href="@ch.ProfileUrl" target="_blank">@@@ch.UniqueId</a></td>
                <td>@ch.DisplayName</td>
                <td>@(ch.IsActive ? "✅" : "❌")</td>
                <td>@ch.LastVideoCount</td>
                <td>@ch.LastCommentCount</td>
                <td>@ch.LastCheckedAt?.ToString("MM-dd HH:mm")</td>
                <td>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleAsync(ch)">Перекл</button>
                    <button class="btn btn-sm btn-outline-danger"    @onclick="() => DeleteAsync(ch)">Удал</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
    <div class="d-flex gap-2 mt-3">
        <input class="form-control" style="max-width:280px" placeholder="@tiktok_username" @bind="_newUniqueId" />
        <button class="btn btn-primary" @onclick="AddAsync">Добавить</button>
        <button class="btn btn-success" @onclick="RunMonitorAsync" disabled="@_monitoring">🔄 Проверить каналы</button>
    </div>
    @if (!string.IsNullOrEmpty(_statusMsg)) { <p class="mt-2 text-success">@_statusMsg</p> }
}

@code {
    bool _loading = true, _monitoring = false;
    List<TrackedChannel> _channels = [];
    string _newUniqueId = "", _statusMsg = "";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        _channels = await ChannelRepo.GetAllAsync();
        _loading  = false;
    }

    async Task ToggleAsync(TrackedChannel ch)
    {
        await using var db = DbFactory.CreateDbContext();
        var row = await db.TrackedChannels.FindAsync(ch.Id);
        if (row is null) return;
        row.IsActive = !row.IsActive;
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    async Task DeleteAsync(TrackedChannel ch)
    {
        await using var db = DbFactory.CreateDbContext();
        var row = await db.TrackedChannels.FindAsync(ch.Id);
        if (row is null) return;
        db.TrackedChannels.Remove(row);
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    async Task AddAsync()
    {
        if (string.IsNullOrWhiteSpace(_newUniqueId)) return;
        var info = await TikTokApi.GetUserInfoAsync(_newUniqueId.Trim());
        await using var db = DbFactory.CreateDbContext();
        db.TrackedChannels.Add(new TrackedChannel
        {
            UniqueId    = _newUniqueId.Trim(),
            UserId      = info?.UserId,
            DisplayName = info?.Nickname,
            ProfileUrl  = info?.ProfileUrl ?? $"https://www.tiktok.com/@{_newUniqueId.Trim()}",
            AvatarUrl   = info?.AvatarThumb,
            IsActive    = true
        });
        await db.SaveChangesAsync();
        _newUniqueId = "";
        await LoadAsync();
    }

    async Task RunMonitorAsync()
    {
        _monitoring = true;
        _statusMsg  = "Проверяю..";
        StateHasChanged();
        await MonitorPipeline.RunAsync();
        _statusMsg  = "✅ Готово";
        _monitoring = false;
        await LoadAsync();
    }
}
