@page "/queries"
@rendermode InteractiveServer
@using TikTokEcoBelarus.Infrastructure
@using TikTokEcoBelarus.Domain.Entities
@using Microsoft.EntityFrameworkCore
@using System.Text.Json
@using System.Text.Encodings.Web
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS

<h4 class="mb-3">🔍 Поисковые запросы</h4>

@if (_loading)
{
    <p>Загрузка...</p>
}
else
{
    <table class="table table-sm table-hover">
        <thead><tr><th>Запрос</th><th>Активен</th><th>Дата</th><th></th></tr></thead>
        <tbody>
        @foreach (var q in _queries)
        {
            <tr>
                <td>@q.Keyword</td>
                <td>@(q.IsActive ? "✅" : "❌")</td>
                <td>@q.CreatedAt.ToString("yyyy-MM-dd")</td>
                <td>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ToggleAsync(q)">Переключить</button>
                    <button class="btn btn-sm btn-outline-danger"    @onclick="() => DeleteAsync(q)">Удалить</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
    <div class="d-flex gap-2 mt-3">
        <input class="form-control" style="max-width:300px" placeholder="Новый запрос" @bind="_newKeyword" />
        <button class="btn btn-primary" @onclick="AddAsync">Добавить</button>
    </div>
}

@code {
    bool _loading = true;
    List<SearchQuery> _queries = [];
    string _newKeyword = "";

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        await using var db = DbFactory.CreateDbContext();
        _queries = await db.SearchQueries.OrderByDescending(q => q.CreatedAt).ToListAsync();
        _loading = false;
    }

    async Task ToggleAsync(SearchQuery q)
    {
        await using var db = DbFactory.CreateDbContext();
        var row = await db.SearchQueries.FindAsync(q.Id);
        if (row is null) return;
        row.IsActive = !row.IsActive;
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    async Task DeleteAsync(SearchQuery q)
    {
        await using var db = DbFactory.CreateDbContext();
        var row = await db.SearchQueries.FindAsync(q.Id);
        if (row is null) return;
        db.SearchQueries.Remove(row);
        await db.SaveChangesAsync();
        await LoadAsync();
    }

    async Task AddAsync()
    {
        if (string.IsNullOrWhiteSpace(_newKeyword)) return;
        await using var db = DbFactory.CreateDbContext();
        db.SearchQueries.Add(new SearchQuery { Keyword = _newKeyword.Trim(), IsActive = true, CreatedAt = DateTime.UtcNow });
        await db.SaveChangesAsync();
        _newKeyword = "";
        await LoadAsync();
    }
}
