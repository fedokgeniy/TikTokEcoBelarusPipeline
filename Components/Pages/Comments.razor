@page "/comments"
@rendermode InteractiveServer
@using TikTokEcoBelarus.Domain.Entities
@using TikTokEcoBelarus.Infrastructure
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject IJSRuntime JS

<h4 class="mb-3">&#x1F4AC; Комментарии к видео</h4>

@if (_loading)
{
    <p>Загрузка...</p>
}
else
{
    <div class="mb-3 d-flex gap-2">
        <input class="form-control" style="max-width:280px" placeholder="Фильтр по videoId" @bind="_filterVideoId" />
        <button class="btn btn-outline-secondary" @onclick="LoadAsync">🔍 Фильтр</button>
    </div>
    <p class="text-muted small">Всего: @_total комментариев (показано @_comments.Count)</p>
    <table class="table table-sm table-hover">
        <thead><tr><th>VideoId</th><th>Автор</th><th>Текст</th><th>Лайки</th><th>Релевантно</th><th>Дата</th></tr></thead>
        <tbody>
        @foreach (var c in _comments)
        {
            <tr>
                <td><small>@c.VideoId[..Math.Min(8,c.VideoId.Length)]...</small></td>
                <td>@c.AuthorUniqueId</td>
                <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@c.Text</td>
                <td>@c.LikeCount</td>
                <td>@(c.IsRelevant.HasValue ? (c.IsRelevant.Value ? "✅" : "❌") : "—")</td>
                <td>@c.CommentCreatedAt.ToString("MM-dd")</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    bool _loading = true;
    string _filterVideoId = "";
    List<VideoComment> _comments = [];
    int _total;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        _loading = true;
        await using var db = DbFactory.CreateDbContext();
        var q = db.VideoComments.AsQueryable();
        if (!string.IsNullOrWhiteSpace(_filterVideoId))
            q = q.Where(c => c.VideoId == _filterVideoId);
        _total    = await q.CountAsync();
        _comments = await q.OrderByDescending(c => c.CommentCreatedAt).Take(200).ToListAsync();
        _loading  = false;
    }
}
