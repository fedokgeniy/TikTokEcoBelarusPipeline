@page "/settings"
@rendermode InteractiveServer
@using TikTokEcoBelarus.Infrastructure
@using TikTokEcoBelarus.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory

<h4 class="mb-4">🤖 Настройки нейросети (Anthropic Claude)</h4>

@if (_loading)
{
    <p>Загрузка...</p>
}
else
{
    <div class="mb-3" style="max-width:480px">
        <label class="form-label">API Key</label>
        <input class="form-control" @bind="_apiKey" />
    </div>
    <div class="mb-3" style="max-width:480px">
        <label class="form-label">Модель</label>
        <input class="form-control" @bind="_model" />
    </div>
    <div class="mb-3">
        <label class="form-label">Системный промт (классификация комментариев)</label>
        <textarea class="form-control" rows="8" @bind="_prompt"></textarea>
    </div>
    <button class="btn btn-primary" @onclick="SaveAsync">Сохранить</button>
    @if (!string.IsNullOrEmpty(_saved)) { <span class="ms-3 text-success">@_saved</span> }
}

@code {
    bool _loading = true;
    string _apiKey = "", _model = "", _prompt = "";
    string _saved = "";

    protected override async Task OnInitializedAsync()
    {
        await using var db = DbFactory.CreateDbContext();
        _apiKey = (await db.AppSettings.FindAsync("claudeApiKey"))?.Value ?? "";
        _model  = (await db.AppSettings.FindAsync("claudeModel"))?.Value  ?? "claude-haiku-4-5";
        _prompt = (await db.AppSettings.FindAsync("classifierPrompt"))?.Value ?? "";
        _loading = false;
    }

    async Task SaveAsync()
    {
        await using var db = DbFactory.CreateDbContext();
        await SetAsync(db, "claudeApiKey",     _apiKey);
        await SetAsync(db, "claudeModel",       _model);
        await SetAsync(db, "classifierPrompt", _prompt);
        await db.SaveChangesAsync();
        _saved = "✅ Сохранено";
    }

    static async Task SetAsync(AppDbContext db, string key, string value)
    {
        var row = await db.AppSettings.FindAsync(key);
        if (row is null) db.AppSettings.Add(new TikTokEcoBelarus.Domain.Entities.AppSetting { Key = key, Value = value });
        else row.Value = value;
    }
}
