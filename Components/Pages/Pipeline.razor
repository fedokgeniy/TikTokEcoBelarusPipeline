@page "/pipeline"
@using TikTokEcoBelarus.Domain.Entities
@using TikTokEcoBelarus.Infrastructure
@using TikTokEcoBelarus.Pipeline
@using Microsoft.EntityFrameworkCore
@inject AppDbContext Db
@inject CollectionPipeline PipelineService
@inject IServiceScopeFactory ScopeFactory

<h4 class="mb-3">⚙️ Pipeline</h4>

<!-- Запуск -->
<div class="card p-3 mb-4">
    <div class="d-flex align-items-center gap-3">
        <button class="btn btn-primary" @onclick="RunPipelineAsync" disabled="@_running">
            @if (_running) { <span>⏳ Выполняется...</span> } else { <span>▶ Запустить pipeline</span> }
        </button>
        @if (_lastRunMessage != null)
        {
            <span class="text-muted small">@_lastRunMessage</span>
        }
    </div>

    @if (_log.Count > 0)
    {
        <div class="mt-3 p-2 bg-dark text-light rounded small"
             style="max-height:200px; overflow-y:auto; font-family:monospace;">
            @foreach (var line in _log)
            {
                <div>@line</div>
            }
        </div>
    }
</div>

<!-- Статистика по запросам -->
<h5 class="mb-3">📈 Статистика поисковых запросов</h5>
@if (_loading)
{
    <p>Загрузка...</p>
}
else
{
    <table class="table table-sm table-hover">
        <thead class="table-dark">
            <tr>
                <th>Запрос</th>
                <th>Тип</th>
                <th>Активен</th>
                <th>Видео не старше</th>
                <th>Последний запуск</th>
                <th>Видео через этот запрос</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in _stats)
            {
                <tr>
                    <td>@s.Value</td>
                    <td><span class="badge bg-secondary">@s.QueryType</span></td>
                    <td>
                        @if (s.IsActive)
                        { <span class="badge bg-success">✓</span> }
                        else
                        { <span class="badge bg-danger">✗</span> }
                    </td>
                    <td>@(s.DateFrom?.ToString("dd.MM.yyyy") ?? "—")</td>
                    <td>@(s.LastRunAt?.ToString("dd.MM.yyyy HH:mm") ?? "Никогда")</td>
                    <td>@s.VideoCount</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    bool _loading = true;
    bool _running = false;
    string? _lastRunMessage;
    List<string> _log = [];
    List<QueryStat> _stats = [];

    protected override async Task OnInitializedAsync() => await LoadStatsAsync();

    async Task LoadStatsAsync()
    {
        _loading = true;
        _stats = await Db.SearchQueries
            .Select(q => new QueryStat
            {
                Value      = q.Value,
                QueryType  = q.QueryType,
                IsActive   = q.IsActive,
                DateFrom   = q.DateFrom,
                LastRunAt  = q.LastRunAt,
                VideoCount = q.VideoLinks.Count
            })
            .OrderBy(s => s.Value)
            .ToListAsync();
        _loading = false;
    }

    async Task RunPipelineAsync()
    {
        _running = true;
        _log.Clear();
        _lastRunMessage = null;

        try
        {
            // Перехватываем Console.WriteLine через StringWriter
            var sw = new StringWriter();
            var old = Console.Out;
            Console.SetOut(sw);

            var results = await PipelineService.RunAsync(minBelarus: 0.3, minEco: 0.3);

            Console.SetOut(old);
            _log = sw.ToString()
                .Split('\n', StringSplitOptions.RemoveEmptyEntries)
                .ToList();

            _lastRunMessage = $"✓ Завершено: найдено {results.Count} видео";
            await LoadStatsAsync();
        }
        catch (Exception ex)
        {
            _lastRunMessage = $"✗ Ошибка: {ex.Message}";
        }
        finally
        {
            _running = false;
        }
    }

    record QueryStat
    {
        public string Value      { get; init; } = "";
        public string QueryType  { get; init; } = "";
        public bool IsActive     { get; init; }
        public DateTime? DateFrom  { get; init; }
        public DateTime? LastRunAt { get; init; }
        public int VideoCount    { get; init; }
    }
}