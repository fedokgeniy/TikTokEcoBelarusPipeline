@page "/pipeline"
@rendermode InteractiveServer
@using TikTokEcoBelarus.Infrastructure
@using TikTokEcoBelarus.Services
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<AppDbContext> DbFactory
@inject PipelineOrchestrator Orchestrator

<h4 class="mb-3">⚙️ Pipeline</h4>

@if (_running)
{
    <p>Пайплайн запущен... @_progressText</p>
}
else if (_lastResult is not null)
{
    @if (_lastResult.Success)
    {
        <div class="alert alert-success">
            ✅ Готово! Найдено: @_lastResult.Found, Сохранено: @_lastResult.Saved, Обновлено: @_lastResult.Skipped (за @_lastResult.Duration.TotalSeconds.ToString("F1")s)
        </div>
    }
    else
    {
        <div class="alert alert-danger">❌ @_lastResult.Error</div>
    }
}

<div class="d-flex gap-2 mb-3">
    <button class="btn btn-primary" @onclick="RunPipeline" disabled="@_running">▶️ Запустить</button>
</div>

<h6>Последние видео (из БД)</h6>
@if (_recentVideos is not null)
{
    <table class="table table-sm table-hover">
        <thead><tr><th>ID</th><th>Автор</th><th>Belarus</th><th>Eco</th><th>Дата</th></tr></thead>
        <tbody>
        @foreach (var v in _recentVideos)
        {
            <tr>
                <td><a href="@v.VideoUrl" target="_blank">@v.VideoId[..8]...</a></td>
                <td>@v.AuthorUniqueId</td>
                <td>@v.BelarusScore.ToString("F2")</td>
                <td>@v.EcoScore.ToString("F2")</td>
                <td>@v.FetchedAt.ToString("MM-dd HH:mm")</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    bool _running;
    string _progressText = "";
    PipelineRunResult? _lastResult;
    List<TikTokEcoBelarus.Domain.Entities.Video>? _recentVideos;

    protected override async Task OnInitializedAsync() => await LoadRecentAsync();

    async Task LoadRecentAsync()
    {
        await using var db = DbFactory.CreateDbContext();
        _recentVideos = await db.Videos
            .OrderByDescending(v => v.FetchedAt)
            .Take(20)
            .ToListAsync();
    }

    async Task RunPipeline()
    {
        _running = true;
        _progressText = "";
        _lastResult = null;
        StateHasChanged();

        var progress = new Progress<PipelineProgress>(p =>
        {
            _progressText = $"{p.Current}/{p.Total} — {p.QueryName}";
            InvokeAsync(StateHasChanged);
        });

        _lastResult = await Orchestrator.RunAsync(progress: progress);
        _running = false;
        await LoadRecentAsync();
        StateHasChanged();
    }
}
